# ========== 阶段一：基础环境 ==========
APP_ENV=development
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///./database/eduagent.db
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=true
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ========== 讯飞星火（密钥只写在 .env，勿提交 Git）==========
# WebSocket（Spark Ultra / v4.0，控制台「Web服务」接口）
SPARK_API_TYPE=websocket
SPARK_APP_ID=你的APPID
SPARK_API_KEY=你的APIKey
SPARK_API_SECRET=你的APISecret
SPARK_WS_URL=wss://spark-api.xf-yun.com/v4.0/chat
SPARK_DOMAIN=4.0Ultra
SPARK_TIMEOUT=120

# 可选：HTTP 开放接口（若使用 http 服务而非 WebSocket）
# SPARK_API_TYPE=http
# SPARK_API_PASSWORD=你的APIPassword
# SPARK_API_URL=https://spark-api-open.xf-yun.com/v1/chat/completions
# SPARK_MODEL=generalv3.5

# ========== 讯飞 ASR 语音识别（阶段七）==========
# 前往 https://console.xfyun.cn/services/iat 创建应用
ASR_APP_ID=你的ASR_APPID
ASR_API_KEY=你的ASR_APIKey
ASR_API_SECRET=你的ASR_APISecret
ASR_WS_URL=wss://raasr.xfyun.cn/v2/recognize

# ========== 讯飞 TTS 语音合成（阶段七）==========
# 前往 https://console.xfyun.cn/services/tts 创建应用
TTS_APP_ID=你的TTS_APPID
TTS_API_KEY=你的TTS_APIKey
TTS_API_SECRET=你的TTS_APISecret
TTS_WS_URL=wss://tts-api.xfyun.cn/v2/tts

# ========== 阶段二：RAG 知识库 ==========
KNOWLEDGE_DIR=./knowledge
CHROMA_PERSIST_DIR=./vector_db/chroma
CHROMA_COLLECTION=eduagent_courses
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
CHUNK_SIZE=500
CHUNK_OVERLAP=80
RAG_TOP_K=4
AUTO_INGEST_ON_STARTUP=false

# ========== 阶段三：学生画像 ==========
PROFILE_CACHE_TTL=3600
